WEATHER_DIR=/data/weather
MOISTURE_DIR=/data/moisture
ASSETS_DIR=/data/assets
GRID_DIR=/data/grid
SIM_DIR=/data/simulation
CONSEQUENCE_DIR=/data/consequence
OUTPUT_DIR=/data/output
