          <mxGeometry x="40" y="370" width="170" height="20" as="geometry"/>
        </mxCell>

        <mxCell id="grid" value="&lt;b&gt;Grid Assembly Service&lt;/b&gt;&lt;br&gt;&lt;font size=&quot;1&quot;&gt;Merges all pipeline outputs into unified Cell2Fire grid&lt;br&gt;Each cell: fuel model + slope + aspect + elevation + moisture&lt;br&gt;Validates layer consistency &amp; alignment&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EDE7F6;strokeColor=#4527A0;strokeWidth=2;fontSize=12;verticalAlign=middle;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="200" y="400" width="500" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="ignition" value="&lt;b&gt;Ignition Service&lt;/b&gt;&lt;br&gt;&lt;font size=&quot;1&quot;&gt;User-defined points (scenario)&lt;br&gt;Probabilistic sampling (FPA FOD)&lt;br&gt;Weighted by fuel/weather&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3E5F5;strokeColor=#7B1FA2;strokeWidth=2;fontSize=12;verticalAlign=middle;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="760" y="400" width="280" height="80" as="geometry"/>
        </mxCell>

        <!-- ==================== LAYER 4: SIMULATION ENGINE ==================== -->
