          <mxGeometry x="40" y="520" width="160" height="20" as="geometry"/>
        </mxCell>

        <mxCell id="cell2fire" value="&lt;b style=&quot;font-size:16px;&quot;&gt;Cell2Fire Simulation Engine&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;font size=&quot;1&quot;&gt;Rothermel-based fire spread on cellular automata grid&lt;br&gt;Single deterministic runs OR Monte Carlo batches (100–10,000 scenarios)&lt;br&gt;Outputs: fire perimeters, rate of spread, intensity per cell per timestep&lt;br&gt;Parallelized C++ core for performance&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FBE9E7;strokeColor=#FF6B35;strokeWidth=3;fontSize=12;verticalAlign=middle;arcSize=10;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="280" y="550" width="640" height="100" as="geometry"/>
        </mxCell>

