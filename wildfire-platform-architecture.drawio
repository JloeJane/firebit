  <diagram id="wildfire-platform" name="Wildfire Modeling Platform Architecture">
    <mxGraphModel dx="1422" dy="762" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1200" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Title -->
        <mxCell id="title" value="&lt;b&gt;WILDFIRE MODELING PLATFORM — SERVICE ARCHITECTURE&lt;/b&gt;&lt;br&gt;Cell2Fire Engine with Modular Data Pipelines" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=16;fontColor=#FF6B35;" vertex="1" parent="1">
          <mxGeometry x="400" y="20" width="600" height="50" as="geometry"/>
        </mxCell>

        <!-- ==================== LAYER 1: USER INPUT ==================== -->
        <mxCell id="layer1_label" value="USER INPUT" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=10;fontColor=#888888;fontStyle=1;letterSpacing=2;" vertex="1" parent="1">
          <mxGeometry x="40" y="80" width="120" height="20" as="geometry"/>
        </mxCell>

        <mxCell id="shapefile" value="&lt;b&gt;Shapefile Ingestion Service&lt;/b&gt;&lt;br&gt;&lt;font size=&quot;1&quot;&gt;Accepts user AOI shapefile&lt;br&gt;Validates geometry &amp; reprojects to EPSG:5070&lt;br&gt;Computes bounding box for tile fetches&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF3E0;strokeColor=#E65100;strokeWidth=2;fontSize=12;verticalAlign=middle;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="480" y="100" width="440" height="80" as="geometry"/>
        </mxCell>

        <!-- ==================== LAYER 2: DATA PIPELINES ==================== -->
        <mxCell id="layer2_label" value="DATA PIPELINES" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=10;fontColor=#888888;fontStyle=1;letterSpacing=2;" vertex="1" parent="1">
          <mxGeometry x="40" y="210" width="140" height="20" as="geometry"/>
        </mxCell>

        <!-- Fuel Pipeline -->
        <mxCell id="fuel" value="&lt;b&gt;Fuel Pipeline&lt;/b&gt;&lt;br&gt;&lt;font size=&quot;1&quot;&gt;LANDFIRE FBFM40 (30m)&lt;br&gt;Scott &amp; Burgan fuel models&lt;br&gt;Clip, resample, assign codes&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#2E7D32;strokeWidth=2;fontSize=11;verticalAlign=middle;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="40" y="240" width="240" height="90" as="geometry"/>
        </mxCell>

        <!-- Topography Pipeline -->
        <mxCell id="topo" value="&lt;b&gt;Topography Pipeline&lt;/b&gt;&lt;br&gt;&lt;font size=&quot;1&quot;&gt;USGS 3DEP DEM (10m/30m)&lt;br&gt;Derives slope, aspect, elevation&lt;br&gt;Aligns to fuel grid resolution&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#1565C0;strokeWidth=2;fontSize=11;verticalAlign=middle;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="320" y="240" width="240" height="90" as="geometry"/>
        </mxCell>

        <!-- Weather Pipeline -->
        <mxCell id="weather" value="&lt;b&gt;Weather Pipeline&lt;/b&gt;&lt;br&gt;&lt;font size=&quot;1&quot;&gt;RAWS / NOAA RTMA / HRRR / gridMET&lt;br&gt;Wind speed &amp; dir, temp, RH&lt;br&gt;Historical distributions + real-time&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FCE4EC;strokeColor=#AD1457;strokeWidth=2;fontSize=11;verticalAlign=middle;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="600" y="240" width="260" height="90" as="geometry"/>
        </mxCell>

        <!-- Fuel Moisture Pipeline -->
        <mxCell id="moisture" value="&lt;b&gt;Fuel Moisture Pipeline&lt;/b&gt;&lt;br&gt;&lt;font size=&quot;1&quot;&gt;Dead fuel: Nelson model (from weather)&lt;br&gt;Live fuel: NFMD + MODIS NDVI&lt;br&gt;1hr, 10hr, 100hr classes&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF8E1;strokeColor=#F57F17;strokeWidth=2;fontSize=11;verticalAlign=middle;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="900" y="240" width="240" height="90" as="geometry"/>
        </mxCell>

        <!-- Assets Pipeline -->
        <mxCell id="assets" value="&lt;b&gt;Assets &amp; Exposure Pipeline&lt;/b&gt;&lt;br&gt;&lt;font size=&quot;1&quot;&gt;MS Building Footprints / OSM&lt;br&gt;Census TIGER / HIFLD&lt;br&gt;Property values / critical infrastructure&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFEBEE;strokeColor=#C62828;strokeWidth=2;fontSize=11;verticalAlign=middle;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="1180" y="240" width="240" height="90" as="geometry"/>
        </mxCell>

        <!-- ==================== LAYER 3: GRID ASSEMBLY ==================== -->
