          <mxGeometry x="40" y="690" width="160" height="20" as="geometry"/>
        </mxCell>

        <mxCell id="consequence" value="&lt;b&gt;Consequence Analysis&lt;/b&gt;&lt;br&gt;&lt;font size=&quot;1&quot;&gt;Overlay fire spread with assets layer&lt;br&gt;Structures exposed, population at risk, estimated $ damage&lt;br&gt;Aggregate across Monte Carlo for probabilistic risk&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFCDD2;strokeColor=#B71C1C;strokeWidth=2;fontSize=12;verticalAlign=middle;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="200" y="720" width="400" height="80" as="geometry"/>
